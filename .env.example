# docker database
DATABASE_URL=postgresql://postgres:postgres@db:5432/nutritrack
# replace in production
# deploy-ul aplicatiei are propriul secret key pe railway unde e deploy-at
SECRET_KEY=string-super-lung-si-secret
# frontend build output
FRONTEND_DIST=/app/frontend/dist

# VAPID keys for browser push notifications
# Generate a key pair with `npx web-push generate-vapid-keys`
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_SUB=mailto:admin@nutritrack.app

# Secret used by the internal reminder cron job
REMINDER_SECRET=replace-with-a-strong-secret

VITE_API_URL=https://nutrition-app-production-ffa6.up.railway.app